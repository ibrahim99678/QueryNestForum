@model QueryNest.Web.Models.Questions.QuestionIndexViewModel

@{
    ViewData["Title"] = "Questions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Questions</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-primary" asp-controller="Questions" asp-action="Create">Ask question</a>
    }
</div>

<form method="get" asp-controller="Questions" asp-action="Index" class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label" for="q">Search</label>
                <input id="q" name="q" value="@Model.Query" class="form-control" placeholder="Search questions..." />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="tagId">Tag</label>
                <select id="tagId" name="tagId" class="form-select" asp-items="Model.TagOptions"></select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="sort">Sort</label>
                <select id="sort" name="sort" class="form-select" asp-items="Model.SortOptions"></select>
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary">Apply</button>
                <a class="btn btn-outline-secondary" asp-controller="Questions" asp-action="Index">Reset</a>
            </div>
        </div>
    </div>
</form>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">No questions yet.</div>
}
else
{
    <div class="text-muted mb-2">
        Showing @Model.Items.Count of @Model.TotalCount
    </div>
    <div class="list-group">
        @foreach (var q in Model.Items)
        {
            <a class="list-group-item list-group-item-action" asp-controller="Questions" asp-action="Details" asp-route-id="@q.QuestionId">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@q.Title</h5>
                    <small class="text-muted">@q.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge bg-light text-dark border">@q.CategoryName</span>
                    <span class="text-muted">by @q.AuthorName</span>
                    <span class="text-muted">•</span>
                    <span class="text-muted">@q.ViewCount views</span>
                    <span class="text-muted">•</span>
                    <span class="text-muted">@q.AnswerCount answers</span>
                    <span class="badge bg-primary">Score: @q.Score</span>
                </div>
            </a>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Questions"
                       asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-q="@Model.Query"
                       asp-route-tagId="@Model.TagId"
                       asp-route-sort="@Model.Sort">Previous</a>
                </li>

                <li class="page-item disabled">
                    <span class="page-link">Page @Model.Page of @Model.TotalPages</span>
                </li>

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Questions"
                       asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-q="@Model.Query"
                       asp-route-tagId="@Model.TagId"
                       asp-route-sort="@Model.Sort">Next</a>
                </li>
            </ul>
        </nav>
    }
}
