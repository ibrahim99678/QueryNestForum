@model QueryNest.Web.Models.Questions.QuestionDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
    var defaultAvatar = Url.Content("~/images/default-avatar.svg");
    var questionAvatar = string.IsNullOrWhiteSpace(Model.AuthorAvatarPath)
        ? defaultAvatar
        : (Model.AuthorAvatarPath.StartsWith("/") ? Model.AuthorAvatarPath : "/" + Model.AuthorAvatarPath);
}

<div class="mb-3">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
            <h2 class="mb-1">@Model.Title</h2>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <span class="badge bg-light text-dark border">@Model.CategoryName</span>
                <span class="text-muted d-flex align-items-center gap-2">
                    <img src="@questionAvatar" alt="Avatar" width="24" height="24" class="rounded-circle border" />
                    <span>by @Model.AuthorName</span>
                </span>
                <span class="text-muted">•</span>
                <span class="text-muted">@Model.ViewCount views</span>
                <span class="text-muted">•</span>
                <span class="text-muted">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                @if (Model.UpdatedAt is not null)
                {
                    <span class="text-muted">•</span>
                    <span class="text-muted">updated @Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                }
            </div>
        </div>

        @if (Model.CanEdit)
        {
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" asp-controller="Questions" asp-action="Edit" asp-route-id="@Model.QuestionId">Edit</a>
                <a class="btn btn-outline-danger" asp-controller="Questions" asp-action="Delete" asp-route-id="@Model.QuestionId">Delete</a>
            </div>
        }
    </div>

    @if (Model.Tags.Count > 0)
    {
        <div class="mt-2 d-flex gap-2 flex-wrap">
            @foreach (var t in Model.Tags)
            {
                <span class="badge bg-secondary">@t</span>
            }
        </div>
    }

    <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
        <span class="badge bg-primary">Score: @Model.Score</span>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Votes" asp-action="Cast" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
                <input type="hidden" name="TargetType" value="1" />
                <input type="hidden" name="TargetId" value="@Model.QuestionId" />
                <input type="hidden" name="VoteType" value="1" />
                <button type="submit" class="btn btn-sm btn-outline-success">Upvote</button>
            </form>
            <form asp-controller="Votes" asp-action="Cast" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
                <input type="hidden" name="TargetType" value="1" />
                <input type="hidden" name="TargetId" value="@Model.QuestionId" />
                <input type="hidden" name="VoteType" value="-1" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Downvote</button>
            </form>
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="md-content" style="white-space: normal;">@Html.Raw(MarkdownLite.ToHtml(Model.Description))</div>
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title mb-2">Report this question</h5>
            <form asp-controller="Reports" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TargetType" value="1" />
                <input type="hidden" name="TargetId" value="@Model.QuestionId" />
                <input type="hidden" name="ReturnQuestionId" value="@Model.QuestionId" />
                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text" name="Reason" class="form-control" placeholder="Reason" required minlength="3" maxlength="200" />
                    </div>
                    <div class="col-md-6">
                        <input type="text" name="Details" class="form-control" placeholder="Details (optional)" maxlength="1000" />
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-outline-danger">Report</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

<div class="mt-4">
    <h4 class="mb-3">Answers</h4>

    @if (Model.CanAnswer)
    {
        <div class="card mb-3">
            <div class="card-body">
                <form asp-controller="Answers" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="QuestionId" value="@Model.QuestionId" />

                    <div class="mb-2">
                        <textarea name="Content" class="form-control" rows="4" placeholder="Write your answer..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Post answer</button>
                </form>
            </div>
        </div>
    }

    @if (Model.Answers.Count == 0)
    {
        <div class="alert alert-info">No answers yet.</div>
    }
    else
    {
        foreach (var answer in Model.Answers)
        {
            var answerAvatar = string.IsNullOrWhiteSpace(answer.AuthorAvatarPath)
                ? defaultAvatar
                : (answer.AuthorAvatarPath.StartsWith("/") ? answer.AuthorAvatarPath : "/" + answer.AuthorAvatarPath);

            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                        <div class="text-muted small d-flex align-items-center gap-2">
                            <img src="@answerAvatar" alt="Avatar" width="24" height="24" class="rounded-circle border" />
                            <span>@answer.AuthorName</span>
                            <span>•</span>
                            <span>@answer.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="badge bg-primary">Score: @answer.Score</span>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (answer.CanEdit)
                                {
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-controller="Answers"
                                       asp-action="Edit"
                                       asp-route-id="@answer.AnswerId">Edit</a>
                                }
                                @if (answer.CanDelete)
                                {
                                    <form asp-controller="Answers" asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@answer.AnswerId" />
                                        <input type="hidden" name="questionId" value="@Model.QuestionId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger js-confirm-delete">Delete</button>
                                    </form>
                                }
                                <form asp-controller="Votes" asp-action="Cast" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
                                    <input type="hidden" name="TargetType" value="2" />
                                    <input type="hidden" name="TargetId" value="@answer.AnswerId" />
                                    <input type="hidden" name="VoteType" value="1" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Upvote</button>
                                </form>
                                <form asp-controller="Votes" asp-action="Cast" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
                                    <input type="hidden" name="TargetType" value="2" />
                                    <input type="hidden" name="TargetId" value="@answer.AnswerId" />
                                    <input type="hidden" name="VoteType" value="-1" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Downvote</button>
                                </form>
                                <form asp-controller="Reports" asp-action="Create" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="TargetType" value="2" />
                                    <input type="hidden" name="TargetId" value="@answer.AnswerId" />
                                    <input type="hidden" name="ReturnQuestionId" value="@Model.QuestionId" />
                                    <input type="hidden" name="Reason" value="Inappropriate" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Report</button>
                                </form>
                            }
                        </div>
                    </div>
                    <div class="md-content" style="white-space: normal;">@Html.Raw(MarkdownLite.ToHtml(answer.Content))</div>

                    <hr class="my-3" />

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Comments</strong>
                    </div>

                    @if (answer.CanComment)
                    {
                        <form asp-controller="Comments" asp-action="Create" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="questionId" value="@Model.QuestionId" />
                            <input type="hidden" name="AnswerId" value="@answer.AnswerId" />
                            <div class="input-group">
                                <input type="text" name="Content" class="form-control" placeholder="Add a comment..." />
                                <button type="submit" class="btn btn-outline-primary">Comment</button>
                            </div>
                        </form>
                    }

                    @if (answer.Comments.Count == 0)
                    {
                        <div class="text-muted">No comments.</div>
                    }
                    else
                    {
                        foreach (var c in answer.Comments)
                        {
                            @await Html.PartialAsync("_Comment", c, new ViewDataDictionary(ViewData)
                            {
                                ["AnswerId"] = answer.AnswerId,
                                ["QuestionId"] = Model.QuestionId,
                                ["CanReply"] = answer.CanComment,
                                ["CanVote"] = User.Identity?.IsAuthenticated == true
                            })
                        }
                    }
                </div>
            </div>
        }
    }
</div>

<div class="mt-3">
    <a class="btn btn-link" asp-controller="Questions" asp-action="Index">Back to list</a>
</div>

@section Scripts {
    <script>
        (() => {
            const modalEl = document.getElementById("confirmDeleteModal");
            const confirmBtn = document.getElementById("confirmDeleteButton");
            if (!modalEl || !confirmBtn) {
                return;
            }

            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            let formToSubmit = null;

            document.addEventListener("click", (e) => {
                const btn = e.target instanceof Element ? e.target.closest(".js-confirm-delete") : null;
                if (!btn) {
                    return;
                }

                const form = btn.closest("form");
                if (!form) {
                    return;
                }

                e.preventDefault();
                formToSubmit = form;
                modal.show();
            });

            confirmBtn.addEventListener("click", () => {
                if (formToSubmit) {
                    formToSubmit.submit();
                }
            });
        })();
    </script>
}
