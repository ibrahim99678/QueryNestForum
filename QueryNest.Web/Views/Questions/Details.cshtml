@model QueryNest.Web.Models.Questions.QuestionDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
            <h2 class="mb-1">@Model.Title</h2>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <span class="badge bg-light text-dark border">@Model.CategoryName</span>
                <span class="text-muted">by @Model.AuthorName</span>
                <span class="text-muted">•</span>
                <span class="text-muted">@Model.ViewCount views</span>
                <span class="text-muted">•</span>
                <span class="text-muted">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                @if (Model.UpdatedAt is not null)
                {
                    <span class="text-muted">•</span>
                    <span class="text-muted">updated @Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                }
            </div>
        </div>

        @if (Model.CanEdit)
        {
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" asp-controller="Questions" asp-action="Edit" asp-route-id="@Model.QuestionId">Edit</a>
                <a class="btn btn-outline-danger" asp-controller="Questions" asp-action="Delete" asp-route-id="@Model.QuestionId">Delete</a>
            </div>
        }
    </div>

    @if (Model.Tags.Count > 0)
    {
        <div class="mt-2 d-flex gap-2 flex-wrap">
            @foreach (var t in Model.Tags)
            {
                <span class="badge bg-secondary">@t</span>
            }
        </div>
    }
</div>

<div class="card">
    <div class="card-body">
        <div style="white-space: pre-wrap;">@Model.Description</div>
    </div>
</div>

@if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

<div class="mt-4">
    <h4 class="mb-3">Answers</h4>

    @if (Model.CanAnswer)
    {
        <div class="card mb-3">
            <div class="card-body">
                <form asp-controller="Answers" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="QuestionId" value="@Model.QuestionId" />

                    <div class="mb-2">
                        <textarea name="Content" class="form-control" rows="4" placeholder="Write your answer..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Post answer</button>
                </form>
            </div>
        </div>
    }

    @if (Model.Answers.Count == 0)
    {
        <div class="alert alert-info">No answers yet.</div>
    }
    else
    {
        foreach (var answer in Model.Answers)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="text-muted small mb-2">
                        <span>@answer.AuthorName</span>
                        <span>•</span>
                        <span>@answer.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div style="white-space: pre-wrap;">@answer.Content</div>

                    <hr class="my-3" />

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Comments</strong>
                    </div>

                    @if (answer.CanComment)
                    {
                        <form asp-controller="Comments" asp-action="Create" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="questionId" value="@Model.QuestionId" />
                            <input type="hidden" name="AnswerId" value="@answer.AnswerId" />
                            <div class="input-group">
                                <input type="text" name="Content" class="form-control" placeholder="Add a comment..." />
                                <button type="submit" class="btn btn-outline-primary">Comment</button>
                            </div>
                        </form>
                    }

                    @if (answer.Comments.Count == 0)
                    {
                        <div class="text-muted">No comments.</div>
                    }
                    else
                    {
                        foreach (var c in answer.Comments)
                        {
                            @await Html.PartialAsync("_Comment", c, new ViewDataDictionary(ViewData)
                            {
                                ["AnswerId"] = answer.AnswerId,
                                ["QuestionId"] = Model.QuestionId,
                                ["CanReply"] = answer.CanComment
                            })
                        }
                    }
                </div>
            </div>
        }
    }
</div>

<div class="mt-3">
    <a class="btn btn-link" asp-controller="Questions" asp-action="Index">Back to list</a>
</div>
