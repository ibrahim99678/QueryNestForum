@model QueryNest.Web.Models.Home.HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="home-hero py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <div class="home-kicker mb-2">Community Q&A</div>
                <h1 class="display-5 fw-semibold mb-3">Ask better questions. Get better answers.</h1>
                <div class="lead text-muted mb-4">
                    QueryNest helps you search, share, and learn faster with voting, topics, and notifications.
                </div>

                <form class="home-search" method="get" asp-controller="Questions" asp-action="Index">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="18" height="18">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85h-.017ZM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0Z"/>
                            </svg>
                        </span>
                        <input class="form-control" type="search" name="q" placeholder="Search questions..." />
                        <button class="btn btn-primary" type="submit">Search</button>
                    </div>
                    <div class="text-muted small mt-2">Try: “EF Core Include”, “JWT”, “upload file”</div>
                </form>

                <div class="d-flex gap-2 mt-4 flex-wrap">
                    <a class="btn btn-primary nav-pill-btn" asp-controller="Questions" asp-action="Index">Browse questions</a>
                    @if (Model.IsAuthenticated)
                    {
                        <a class="btn btn-outline-secondary nav-pill-btn" asp-controller="Questions" asp-action="Create">Ask a question</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-secondary nav-pill-btn" asp-controller="Account" asp-action="Register">Create account</a>
                    }
                    <a class="btn btn-outline-secondary nav-pill-btn" asp-controller="Tags" asp-action="Index">Explore topics</a>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="card home-stat h-100">
                            <div class="card-body">
                                <div class="text-muted">Users</div>
                                <div class="h3 mb-0">@Model.TotalUsers</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card home-stat h-100">
                            <div class="card-body">
                                <div class="text-muted">Questions</div>
                                <div class="h3 mb-0">@Model.TotalQuestions</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card home-stat h-100">
                            <div class="card-body">
                                <div class="text-muted">Answers</div>
                                <div class="h3 mb-0">@Model.TotalAnswers</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card home-stat h-100">
                            <div class="card-body">
                                <div class="text-muted">Topics</div>
                                <div class="h3 mb-0">@Model.TotalTags</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card home-callout">
                            <div class="card-body">
                                <div class="fw-semibold mb-1">Pro tip</div>
                                <div class="text-muted">
                                    Use ==highlight==, `inline code`, and code blocks in descriptions for clear questions.
                                </div>
                                <div class="mt-3 d-flex gap-2">
                                    <a class="btn btn-outline-secondary btn-sm nav-pill-btn" asp-controller="Questions" asp-action="Create">Try the editor</a>
                                    <a class="btn btn-outline-secondary btn-sm nav-pill-btn" asp-controller="Dashboard" asp-action="Index">Your stats</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h4 class="mb-0">Trending topics</h4>
                <a class="small text-decoration-none" asp-controller="Tags" asp-action="Index">View all</a>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">
                @foreach (var t in Model.TrendingTags)
                {
                    <div class="home-topic">
                        <a class="btn btn-sm btn-outline-primary nav-pill-btn" asp-controller="Tags" asp-action="Details" asp-route-id="@t.TagId">
                            @t.Name
                            <span class="badge bg-light text-dark border ms-1">@t.QuestionCount</span>
                        </a>
                        @if (Model.IsAuthenticated)
                        {
                            <form asp-controller="Tags" asp-action="ToggleFollow" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.TagId" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm @(t.IsFollowed ? "btn-primary" : "btn-outline-secondary") nav-pill-btn">
                                    @(t.IsFollowed ? "Following" : "Follow")
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <h4 class="mb-0">Popular categories</h4>
                <a class="small text-decoration-none" asp-controller="Questions" asp-action="Index">Browse</a>
            </div>

            @if (Model.PopularCategories.Count == 0)
            {
                <div class="text-muted">No categories yet.</div>
            }
            else
            {
                <div class="list-group home-list">
                    @foreach (var c in Model.PopularCategories)
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Questions" asp-action="Index" asp-route-categoryId="@c.CategoryId">
                            <div class="d-flex justify-content-between gap-3">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@c.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(c.Description))
                                    {
                                        <div class="small text-muted">@c.Description</div>
                                    }
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-light text-dark border">@c.QuestionCount</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h4 class="mb-0">Latest questions</h4>
                <a class="small text-decoration-none" asp-controller="Questions" asp-action="Index">Browse</a>
            </div>

            @if (Model.LatestQuestions.Count == 0)
            {
                <div class="alert alert-info">No questions yet.</div>
            }
            else
            {
                <div class="list-group home-list">
                    @foreach (var q in Model.LatestQuestions)
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Questions" asp-action="Details" asp-route-id="@q.QuestionId">
                            <div class="d-flex justify-content-between gap-3">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold mb-1">@q.Title</div>
                                    <div class="d-flex gap-2 flex-wrap small text-muted">
                                        <span class="badge bg-light text-dark border">@q.CategoryName</span>
                                        <span>by @q.AuthorName</span>
                                        <span>•</span>
                                        <span>@q.ViewCount views</span>
                                        <span>•</span>
                                        <span>@q.AnswerCount answers</span>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="badge bg-primary">Score: @q.Score</div>
                                    <div class="small text-muted mt-1">@q.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
