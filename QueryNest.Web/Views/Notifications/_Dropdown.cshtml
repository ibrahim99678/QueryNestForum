@model QueryNest.Web.Models.Notifications.NotificationListViewModel

@if (Model.Items.Count == 0)
{
    <li class="px-3 py-2 text-muted">No notifications.</li>
}
else
{
    foreach (var n in Model.Items)
    {
        var linkController = "Notifications";
        var linkAction = "Index";
        var routeId = (int?)null;

        if (n.QuestionId is not null)
        {
            linkController = "Questions";
            linkAction = "Details";
            routeId = n.QuestionId;
        }

        <li>
            <a class="dropdown-item @(n.IsRead ? "" : "fw-semibold")" asp-controller="@linkController" asp-action="@linkAction" asp-route-id="@routeId">
                <div class="small">@n.Message</div>
                <div class="text-muted small">@n.CreatedAt.ToLocalTime().ToString("MM-dd HH:mm")</div>
            </a>
        </li>
    }
}

<li><hr class="dropdown-divider" /></li>
<li class="px-3 py-2 d-flex justify-content-between align-items-center">
    <a class="btn btn-sm btn-outline-primary" asp-controller="Notifications" asp-action="Index">View all</a>
    <form asp-controller="Notifications" asp-action="MarkAllRead" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-outline-secondary">Mark all read</button>
    </form>
</li>
