@model List<QueryNest.Web.Models.Categories.CategoryListItemViewModel>

@{
    ViewData["Title"] = "Manage Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Categories</h2>
    <a class="btn btn-primary" asp-controller="Categories" asp-action="Create">Create category</a>
</div>

@if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-info">No categories.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Questions</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Name</td>
                        <td class="text-muted">@c.Description</td>
                        <td>@c.QuestionCount</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Categories" asp-action="Edit" asp-route-id="@c.CategoryId">Edit</a>
                            <form asp-controller="Categories" asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.CategoryId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
