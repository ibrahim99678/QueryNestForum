<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QueryNest.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QueryNest.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar app-navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Questions" asp-action="Index">
                    <img src="~/images/default-avatar.svg" alt="QueryNest" class="brand-mark" />
                    <span>QueryNest</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNavbar" aria-controls="appNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="appNavbar">
                    <ul class="navbar-nav me-3">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Questions" asp-action="Index">Questions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Tags" asp-action="Index">Topics</a>
                        </li>
                    </ul>

                    <form class="navbar-search d-none d-lg-block me-lg-3" method="get" asp-controller="Questions" asp-action="Index">
                        <span class="search-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85h-.017ZM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0Z"/>
                            </svg>
                        </span>
                        <input id="navbarSearchInput" class="form-control" type="search" name="q" placeholder="Search questions..." aria-label="Search" autocomplete="off" />
                        <div id="navbarSearchSuggest" class="navbar-search-suggest d-none"></div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-lg-none">
                                <form class="px-2" method="get" asp-controller="Questions" asp-action="Index">
                                    <input class="form-control" type="search" name="q" placeholder="Search questions..." aria-label="Search" />
                                </form>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary nav-icon-btn d-none d-lg-inline-flex" asp-area="" asp-controller="Questions" asp-action="Create" aria-label="Ask">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                        <path d="M8 2a.5.5 0 0 1 .5.5V7.5H13.5a.5.5 0 0 1 0 1H8.5V13.5a.5.5 0 0 1-1 0V8.5H2.5a.5.5 0 0 1 0-1H7.5V2.5A.5.5 0 0 1 8 2Z"/>
                                    </svg>
                                </a>
                                <a class="btn btn-primary nav-pill-btn d-lg-none" asp-area="" asp-controller="Questions" asp-action="Create">Ask</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-secondary nav-pill-btn" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="btn btn-outline-secondary nav-pill-btn dropdown-toggle" href="#" id="notifDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Notifications
                                    <span id="notifCountBadge" class="badge bg-danger ms-1 d-none"></span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="notifDropdown" style="min-width: 320px;">
                                    <li id="notifDropdownBody" class="px-3 py-2 text-muted">Loading...</li>
                                </ul>
                            </li>
                            @await Component.InvokeAsync("UserNav")
                        }
                        else
                        {
                            <li class="nav-item d-lg-none">
                                <form class="px-2" method="get" asp-controller="Questions" asp-action="Index">
                                    <input class="form-control" type="search" name="q" placeholder="Search questions..." aria-label="Search" />
                                </form>
                            </li>
                            @await Component.InvokeAsync("UserNav")
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - QueryNest.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
