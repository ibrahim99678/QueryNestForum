@model QueryNest.Web.Models.Profile.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body">
                <h2 class="h4 mb-1">@(Model.HasPassword ? "Change password" : "Set password")</h2>
                <div class="text-muted mb-4">
                    @(Model.HasPassword ? "Update your account password." : "Set a password for your account.")
                </div>

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    @if (Model.HasPassword)
                    {
                        <div class="mb-3 auth-input">
                            <label asp-for="CurrentPassword" class="form-label">Current password</label>
                            <span class="auth-input-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                    <path d="M8 1a4 4 0 0 0-4 4v3H3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2h-1V5a4 4 0 0 0-4-4Zm3 7H5V5a3 3 0 1 1 6 0v3Z"/>
                                </svg>
                            </span>
                            <input asp-for="CurrentPassword" id="CurrentPassword" class="form-control form-control-lg" autocomplete="current-password" />
                            <button type="button" class="auth-toggle js-toggle-password" data-target="#CurrentPassword" aria-label="Show password"></button>
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>
                    }

                    <div class="mb-3 auth-input">
                        <label asp-for="NewPassword" class="form-label">New password</label>
                        <span class="auth-input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M8 1a4 4 0 0 0-4 4v3H3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2h-1V5a4 4 0 0 0-4-4Zm3 7H5V5a3 3 0 1 1 6 0v3Z"/>
                            </svg>
                        </span>
                        <input asp-for="NewPassword" id="NewPassword" class="form-control form-control-lg" autocomplete="new-password" />
                        <button type="button" class="auth-toggle js-toggle-password" data-target="#NewPassword" aria-label="Show password"></button>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3 auth-input">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
                        <span class="auth-input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M8 1a4 4 0 0 0-4 4v3H3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2h-1V5a4 4 0 0 0-4-4Zm3 7H5V5a3 3 0 1 1 6 0v3Z"/>
                            </svg>
                        </span>
                        <input asp-for="ConfirmPassword" id="ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" />
                        <button type="button" class="auth-toggle js-toggle-password" data-target="#ConfirmPassword" aria-label="Show password"></button>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1">Save</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

