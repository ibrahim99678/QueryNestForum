@model QueryNest.Web.Models.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-shell d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-9">
                <div class="card auth-card">
                    <div class="row g-0">
                        <div class="col-md-5 d-none d-md-flex auth-left p-4 p-lg-5">
                            <div class="d-flex flex-column gap-3 w-100">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/default-avatar.svg" width="34" height="34" alt="QueryNest" class="rounded-circle border border-light border-opacity-25" />
                                    <div class="h4 mb-0 auth-brand">QueryNest</div>
                                </div>
                                <div class="h2 mb-0">Welcome back</div>
                                <div class="auth-subtitle">
                                    Sign in to continue asking, answering, voting, and following topics.
                                </div>
                                <div class="mt-auto auth-subtitle small">
                                    Tip: Use a strong password and keep your account secure.
                                </div>
                            </div>
                        </div>
                        <div class="col-md-7 auth-form p-4 p-lg-5">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div>
                                    <h2 class="mb-1">Login</h2>
                                    <div class="text-muted">Use your email and password.</div>
                                </div>
                                <a class="btn btn-outline-secondary btn-sm" asp-controller="Account" asp-action="Register">Create account</a>
                            </div>

                            <form asp-action="Login" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="ReturnUrl" />

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="mb-3 auth-input">
                                    <label asp-for="Email" class="form-label"></label>
                                    <span class="auth-input-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                            <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.552L0 4.697ZM6.761 8.83l-6.57 4.026A2 2 0 0 0 2 14h12a2 2 0 0 0 1.809-1.144l-6.57-4.026L8 9.586l-1.239-.757ZM10.197 8.249 16 11.801V4.697l-5.803 3.552Z"/>
                                        </svg>
                                    </span>
                                    <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="mb-3 auth-input">
                                    <label asp-for="Password" class="form-label"></label>
                                    <span class="auth-input-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
                                            <path d="M8 1a4 4 0 0 0-4 4v3H3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2h-1V5a4 4 0 0 0-4-4Zm3 7H5V5a3 3 0 1 1 6 0v3Z"/>
                                        </svg>
                                    </span>
                                    <input asp-for="Password" id="LoginPassword" class="form-control form-control-lg" autocomplete="current-password" />
                                    <button type="button" class="auth-toggle js-toggle-password" data-target="#LoginPassword" aria-label="Show password"></button>
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" asp-for="RememberMe" />
                                        <label class="form-check-label" asp-for="RememberMe"></label>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-lg w-100">Login</button>
                            </form>

                            <div class="mt-4 text-muted small">
                                New here? <a asp-controller="Account" asp-action="Register">Register now</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
