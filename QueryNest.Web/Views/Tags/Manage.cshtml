@model List<QueryNest.Web.Models.Tags.TagListItemViewModel>

@{
    ViewData["Title"] = "Manage Tags";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Manage tags</h2>
    <a class="btn btn-primary" asp-controller="Tags" asp-action="Create">Create tag</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No tags.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Tag</th>
                    <th>Slug</th>
                    <th>Questions</th>
                    <th>Followers</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Tags" asp-action="Details" asp-route-id="@t.TagId">@t.Name</a>
                        </td>
                        <td class="text-muted">@t.Slug</td>
                        <td>@t.QuestionCount</td>
                        <td>@t.FollowerCount</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Tags" asp-action="Edit" asp-route-id="@t.TagId">Edit</a>
                            <form asp-controller="Tags" asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.TagId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
