@model QueryNest.Web.Models.Tags.TagDetailsViewModel

@{
    ViewData["Title"] = $"Tag: {Model.Tag.Name}";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h2 class="mb-1">@Model.Tag.Name</h2>
        <div class="text-muted">@Model.Tag.Slug</div>
        <div class="mt-2 d-flex gap-2 flex-wrap">
            <span class="badge bg-light text-dark border">@Model.Tag.QuestionCount questions</span>
            <span class="badge bg-light text-dark border">@Model.Tag.FollowerCount followers</span>
        </div>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <form asp-controller="Tags" asp-action="ToggleFollow" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Tag.TagId" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <button type="submit" class="btn @(Model.Tag.IsFollowed ? "btn-primary" : "btn-outline-primary")">
                @(Model.Tag.IsFollowed ? "Following" : "Follow")
            </button>
        </form>
    }
</div>

@if (Model.Questions.Count == 0)
{
    <div class="alert alert-info">No questions for this tag yet.</div>
}
else
{
    <div class="list-group">
        @foreach (var q in Model.Questions)
        {
            <a class="list-group-item list-group-item-action" asp-controller="Questions" asp-action="Details" asp-route-id="@q.QuestionId">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@q.Title</h5>
                    <small class="text-muted">@q.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge bg-light text-dark border">@q.CategoryName</span>
                    <span class="text-muted">by @q.AuthorName</span>
                    <span class="text-muted">•</span>
                    <span class="text-muted">@q.ViewCount views</span>
                    <span class="text-muted">•</span>
                    <span class="text-muted">@q.AnswerCount answers</span>
                    <span class="badge bg-primary">Score: @q.Score</span>
                </div>
            </a>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Tags"
                       asp-action="Details"
                       asp-route-id="@Model.Tag.TagId"
                       asp-route-page="@(Model.Page - 1)">Previous</a>
                </li>

                <li class="page-item disabled">
                    <span class="page-link">Page @Model.Page of @Model.TotalPages</span>
                </li>

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-controller="Tags"
                       asp-action="Details"
                       asp-route-id="@Model.Tag.TagId"
                       asp-route-page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
