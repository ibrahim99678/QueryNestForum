@model QueryNest.Web.Models.Comments.CommentEditViewModel

@{
    ViewData["Title"] = "Edit comment";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="mb-3">Edit comment</h2>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CommentId" />
            <input type="hidden" asp-for="QuestionId" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-controller="Questions" asp-action="Details" asp-route-id="@Model.QuestionId">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
